{
  "env": {
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8",
    "PYTHONUTF8": "1",
    "PYTHONIOENCODING": "utf-8"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm --prefix * test)",
      "Bash(npm --prefix * run *)",
      "Bash(git -C * status)",
      "Bash(git -C * diff)",
      "Bash(git -C * log *)",
      "Bash(make -C * test)",
      "Bash(pnpm --dir * *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Read",
      "Edit(src/**)",
      "Write(src/**)",
      "Edit(packages/**)",
      "Write(packages/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(rm *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(git push --force *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)"
    ]
  }
}
